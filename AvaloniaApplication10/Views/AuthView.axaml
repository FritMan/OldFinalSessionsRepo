<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaApplication10.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="AvaloniaApplication10.Views.AuthView"
             x:DataType="vm:MainViewModel">

    <StackPanel >
        <StackPanel Name="LoginStack" >
            <Label Content="Логин" />
            <TextBox Name="LogiTb" />
            <Label Content="Пароль"/>
            <TextBox Name="PasswordTb" PasswordChar="*"/>
            <Button Name="OkBtn" Click="OkBtn_OnClick" Content="Ок"/>
        </StackPanel>

        
        <StackPanel Orientation="Vertical" Name="CodeStack" IsVisible="False">
            <Label Content="Код"/>
            <TextBox Name="PassCodeTb"/>
            <Button Click="CodeBtn_OnClick" Name="CodeBtn" Content="Войти"/>
        </StackPanel>
    </StackPanel>

</UserControl>
